[remap]

importer="csv_translation"
type="Translation"

[deps]

files=[ "res://mods-unpacked/Yoko-Ghostato/translations/Ghostato.en.translation", "res://mods-unpacked/Yoko-Ghostato/translations/Ghostato.zh.translation" ]

source_file="res://mods-unpacked/Yoko-Ghostato/translations/Ghostato.csv"
dest_files=[ "res://mods-unpacked/Yoko-Ghostato/translations/Ghostato.en.translation", "res://mods-unpacked/Yoko-Ghostato/translations/Ghostato.zh.translation" ]

[params]

compress=true
delimiter=0
